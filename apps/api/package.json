    "@nestjs/cli": "10.4.9",
    "@nestjs/schematics": "10.2.3",
    "@nestjs/testing": "10.4.15",
    "@types/node": "22.10.5",
    "@types/bcryptjs": "2.4.6",
    "@types/jsonwebtoken": "9.0.9",
